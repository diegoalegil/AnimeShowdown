/en                       /en/index.html 200
/en/personajes            /en/personajes/index.html 200
/en/animes                /en/animes/index.html 200
/en/comparar              /en/comparar/index.html 200
/en/ranking               /en/ranking/index.html 200
/en/votar                 /en/votar/index.html 200
/en/games                 /en/games/index.html 200
/en/juegos/anime          /en/juegos/anime/index.html 200

