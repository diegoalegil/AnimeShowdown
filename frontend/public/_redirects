# Rebrand de Anime Daily Trials — 301 a nivel CDN para
# preservar el SEO acumulado de las rutas viejas. Las nuevas son más
# memorables y dan identidad ("ELO Duel" en vez de "Higher or Lower").
# Estos 301 se procesan ANTES de servir el index.html, así Google los
# sigue sin pasar por React Router.
/privacy                  /privacidad                 301
/privacy/*                /privacidad                 301
/terms                    /terminos                   301
/terms/*                  /terminos                   301
/games/guess-character    /games/shadow-guess        301
/games/guess-character/*  /games/shadow-guess/:splat 301
/games/guess-anime        /games/anime-reveal        301
/games/guess-anime/*      /games/anime-reveal/:splat 301
/games/anidel             /games/anigrid             301
/games/anidel/*           /games/anigrid/:splat      301
/games/impostor           /games/impostor-trial      301
/games/impostor/*         /games/impostor-trial/:splat 301
/higher-or-lower          /games/elo-duel            301
/higher-or-lower/*        /games/elo-duel/:splat     301
/glosario                 /glossary                  301
/glosario/*               /glossary                  301
/random                   /descubre-personaje        301
/random/*                 /descubre-personaje        301
/mision-diaria            /misiones                  301
/mision-diaria/*          /misiones                  301
/versus                   /comparar                  301
/compare                  /comparar                  301
/ranking-personal         /mi-ranking                301
/mi-ranking-personal      /mi-ranking                301
/rankings                 /ranking                   301
/rankings/                /ranking                   301

# Rutas SEO prerenderizadas. Deben servir su propio HTML inicial para que
# title/canonical/JSON-LD existan antes del bootstrap de React.
/personajes               /personajes/index.html 200
/animes                   /animes/index.html 200
# Vista constelación: SPA pura (noindex), ANTES del catch :slug para que no
# intente servir un prerender /animes/constelacion/index.html inexistente.
/animes/constelacion      /index.html 200
/animes/:slug/ranking     /animes/:slug/ranking/index.html 200
/animes/:slug             /animes/:slug/index.html 200
/versus/:par              /versus/:par/index.html 200
/comparar                 /comparar/index.html 200
/ranking                  /ranking/index.html 200
/votar                    /votar/index.html 200
/games                    /games/index.html 200
/juegos/anime             /juegos/anime/index.html 200
# EN-first: money pages prerenderizadas en inglés (meta + hreflang). Cada /en/X
