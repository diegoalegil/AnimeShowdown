# Headers de seguridad aplicados a todas las rutas servidas por Cloudflare Pages.
# Doc: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=()
  # script-src queda sin 'unsafe-inline'. style-src-attr mantiene compatibilidad
  # con style props dinámicas de React; retirarlo requiere un refactor visual dedicado.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com; script-src-elem 'self' https://challenges.cloudflare.com; script-src-attr 'none'; worker-src 'self' blob:; style-src 'self' https://fonts.googleapis.com; style-src-elem 'self' https://fonts.googleapis.com; style-src-attr 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://assets.animeshowdown.dev https://cdn.myanimelist.net https://avatars.githubusercontent.com https://lh3.googleusercontent.com; connect-src 'self' https://api.animeshowdown.dev wss://api.animeshowdown.dev https://api.jikan.moe https://animechan.io https://*.sentry.io https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'; upgrade-insecure-requests

# Mientras el catálogo de cartas sigue en curación activa, NO marcamos /img/*
# como immutable: muchas imágenes conservan el mismo slug/path entre iteraciones.
# Con immutable + SW CacheFirst, sesiones antiguas podían quedarse días con una
# carta vieja o rota aunque el deploy ya tuviera la versión correcta.
/img/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Mismo razonamiento que /img/*: los assets de anime-banners, brand,
# game-covers, tournament-banners, event-covers, empty-states y error-scenes
# tienen path estable (slug por anime/torneo/evento) y se sobrescriben
# entre tandas de arte sin cambiar de nombre. NO pueden ser immutable o el
# CDN sirve cache stale tras cada update visual (problema observado tras tanda 3).
/assets/anime-banners/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/brand/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/game-covers/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/tournament-banners/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/event-covers/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/empty-states/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/error-scenes/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
# Mismo razonamiento (arte de marca con path estable, se sobrescribe entre
# tandas): overlays, particles, cartas especiales y fallbacks. Antes caían en
# la regla genérica /assets/* immutable y quedaban cacheados 1 año.
/assets/overlays/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/particles/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/cartas-especiales/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/assets/fallbacks/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Bundles JS/CSS de Vite: hash en el filename (index-B7ScjF8C.js etc.), sí
# pueden ser immutable porque el nombre cambia con cada build.
#
# IMPORTANTE: la regla se limita a los bundles hasheados (.js/.css en la raíz
# de /assets/). La regla genérica `/assets/*` anterior matcheaba TAMBIÉN las
# subcarpetas de arte de arriba y, como Cloudflare Pages COMBINA las cabeceras
# de todas las reglas que casan, su Cache-Control acababa con `immutable`
# (verificado en prod: anime-banners/brand servían max-age=1año immutable) —
# reintroduciendo el bug de arte stale que las reglas anti-stale evitan. Acotar
# por extensión deja el arte fuera (no hay .js/.css en las subcarpetas de arte).
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# El SW y el script de push importado se sirven con el default de Cloudflare
# (max-age 14400): un deploy que toque push-sw.js puede activar el SW nuevo
# ejecutando el handler de push viejo hasta 4h. Los fetch de update del SW son
# poco frecuentes; servirlos sin caché evita ese skew silencioso.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/push-sw.js
  Cache-Control: public, max-age=0, must-revalidate

# index.html nunca se cachea: siempre debe servir la versión más nueva del SPA
/
  Cache-Control: public, max-age=0, must-revalidate

# Fuentes self-host de la display: el nombre lleva hash de contenido
# (subset-display-font.mjs), así que pueden ser immutable sin riesgo de stale.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
