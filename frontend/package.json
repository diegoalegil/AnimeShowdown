{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 vite",
    "build": "node scripts/generate-dominant-colors.mjs && node ../scripts/generate-sitemap.mjs && NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "build:no-images": "node ../scripts/generate-sitemap.mjs && ANIMESHOWDOWN_SKIP_IMG_COPY=true NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "build:no-sitemap": "NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "build:e2e": "VITE_API_BASE_URL=${E2E_API_URL:-http://127.0.0.1:8080} npm run build:no-sitemap",
    "build:sitemap": "node ../scripts/generate-sitemap.mjs",
    "build:images": "node scripts/generate-image-variants.mjs",
    "build:colors": "node scripts/generate-dominant-colors.mjs",
    "build:stage-assets": "node scripts/generate-stage-assets.mjs",
    "assets:cdn:plan": "node ../scripts/sync-img-cdn.mjs --plan",
    "assets:cdn:dry-run": "node ../scripts/sync-img-cdn.mjs --aws-dry-run",
    "assets:cdn:sync": "node ../scripts/sync-img-cdn.mjs --apply",
    "test:bundle": "node scripts/check-bundle-budget.mjs && node scripts/check-pwa-cache-policy.mjs && node scripts/check-security-headers.mjs && node scripts/check-route-policy.mjs && node scripts/check-seo-static.mjs",
    "test:e2e": "playwright test",
    "test:e2e:local": "E2E_BASE_URL=${E2E_BASE_URL:-http://127.0.0.1:4173} E2E_API_URL=${E2E_API_URL:-http://127.0.0.1:8080} playwright test",
    "lint": "eslint .",
    "preview": "NODE_OPTIONS=--disable-warning=DEP0205 vite preview",
    "qa:a11y": "node scripts/check-a11y.mjs",
    "qa:pwa-runtime": "node scripts/check-pwa-runtime.mjs",
    "qa:routes": "node scripts/check-route-policy.mjs",
    "qa:seo": "node scripts/check-seo-static.mjs",
    "qa:responsive": "node scripts/check-responsive.mjs"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@sentry/react": "^10.53.1",
    "@stomp/stompjs": "^7.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "axe-core": "^4.11.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "beasties": "^0.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0"
  }
}
