{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=DEP0205 vite",
    "build": "node scripts/generate-dominant-colors.mjs && node ../scripts/generate-sitemap.mjs && cross-env NODE_OPTIONS=--disable-warning=DEP0205 vite build && node ../scripts/prerender-seo.mjs && node ../scripts/strip-deploy-sourcemaps.mjs",
    "build:no-images": "node ../scripts/generate-sitemap.mjs && cross-env ANIMESHOWDOWN_SKIP_IMG_COPY=true NODE_OPTIONS=--disable-warning=DEP0205 vite build && node ../scripts/prerender-seo.mjs && node ../scripts/strip-deploy-sourcemaps.mjs",
    "build:no-sitemap": "cross-env NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "build:e2e": "VITE_API_URL=${E2E_API_URL:-http://127.0.0.1:8080} npm run build:no-sitemap",
    "build:sitemap": "node ../scripts/generate-sitemap.mjs",
    "build:images": "node scripts/generate-image-variants.mjs",
    "build:images:check": "node scripts/generate-image-variants.mjs --check --strict",
    "build:optimize-assets": "node scripts/optimize-source-assets.mjs",
    "build:optimize-assets:check": "node scripts/optimize-source-assets.mjs --check",
    "build:cover-variants": "node scripts/generate-cover-variants.mjs",
    "build:cover-variants:check": "node scripts/generate-cover-variants.mjs --check",
    "build:colors": "node scripts/generate-dominant-colors.mjs",
    "build:stage-assets": "node scripts/generate-stage-assets.mjs",
    "build:atmosphere-assets": "node scripts/generate-atmosphere-assets.mjs",
    "build:display-font": "node scripts/subset-display-font.mjs",
    "build:display-font:check": "node scripts/subset-display-font.mjs --check",
    "assets:cdn:plan": "node ../scripts/sync-img-cdn.mjs --plan",
    "assets:cdn:dry-run": "node ../scripts/sync-img-cdn.mjs --dry-run",
    "assets:cdn:sync": "node ../scripts/sync-img-cdn.mjs --apply",
    "test:bundle": "node scripts/check-bundle-budget.mjs",
    "test:a11y": "playwright test e2e/a11y.spec.js",
    "test:e2e": "playwright test",
    "test:e2e:local": "E2E_BASE_URL=${E2E_BASE_URL:-http://127.0.0.1:4173} E2E_API_URL=${E2E_API_URL:-http://127.0.0.1:8080} playwright test",
    "test:e2e:responsive": "playwright test e2e/home-responsive.spec.js",
    "test:seo-schema": "node scripts/validate-seo-schema.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && node ../scripts/check-color-literals.mjs && node scripts/subset-display-font.mjs --check",
    "typecheck": "tsc --noEmit",
    "preview": "cross-env NODE_OPTIONS=--disable-warning=DEP0205 vite preview",
    "qa:a11y": "npx --yes @axe-core/cli@4.11.0 http://localhost:4173/ http://localhost:4173/personajes http://localhost:4173/animes http://localhost:4173/torneos http://localhost:4173/ranking http://localhost:4173/login http://localhost:4173/register --tags wcag2a,wcag2aa,wcag21a,wcag21aa --exit"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@sentry/react": "^10.57.0",
    "@stomp/stompjs": "^7.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.11.4",
    "beasties": "^0.4.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.5.0",
    "happy-dom": "^20.10.3",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
