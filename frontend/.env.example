# URL pública del backend Spring Boot.
# En producción esta variable es obligatoria: no hay fallback silencioso a prod.
# Para previews/staging, usa SIEMPRE el subdominio API y no el dominio bruto de Railway:
# OAuth y refresh dependen de cookies en api.animeshowdown.dev.
# Para desarrollo local apuntando a tu Spring Boot:
#   VITE_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=
# Alias legacy aceptado por compatibilidad temporal. Preferir VITE_API_BASE_URL.
VITE_API_URL=

# CDN/origen publico que sirve el arbol de imagenes /img/ para builds de
# produccion ligeros. Debe mapear directamente al root de /img:
#   /img/One_Piece/luffy.webp -> ${ANIMESHOWDOWN_IMG_CDN_BASE_URL}/One_Piece/luffy.webp
#   /img/stage/home-hero.webp -> ${ANIMESHOWDOWN_IMG_CDN_BASE_URL}/stage/home-hero.webp
# Ejemplo:
#   ANIMESHOWDOWN_IMG_CDN_BASE_URL=https://assets.animeshowdown.dev/img
# `npm run build:no-images` exige esta variable y no copia /img/ a dist.
ANIMESHOWDOWN_IMG_CDN_BASE_URL=
# Alias legacy aceptado por compatibilidad temporal.
ANIMESHOWDOWN_IMAGE_CDN_BASE_URL=

# Optional runtime integrations.
VITE_SENTRY_DSN=
VITE_ANIMECHAN_ENABLED=
