# Salida del POC de regeneración de recortes (scripts/regen-cuts.mjs):
# previews para inspección, no se commitean.
scripts/.regen-cuts-out/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Variantes responsive de imágenes:
#   - -300.webp y -600.webp SÍ se commitean — Cloudflare Pages las sirve
#     directamente sin regenerar en cada build (esquiva timeout de 20 min).
#   - -1024.webp se omite (el original ya cubre ese ancho).
#   - AVIF se omite (sumaría +250MB al repo sin ganancia visible vs WebP).
img/**/*-1024.webp
img/**/*.avif
