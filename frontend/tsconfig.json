{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "types": ["vite/client", "react", "react-dom", "node"]
  },
  "include": [
    "src/lib/**/*.ts",
    "src/test/**/*.ts",
    "src/features/cartas/forge/forge-core.ts",
    "src/components/GameCatalogLoading.tsx",
    "src/components/MonedaIcon.tsx",
    "src/components/Skeleton.tsx"
  ]
}
