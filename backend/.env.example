# AnimeShowdown backend environment inventory.
# Copy to .env only if your local runner loads it. Keep real values in your
# provider secret store for production. Values are intentionally blank here.
#
# REQUIRED in production (ProductionSecretsValidator aborta el arranque si
# siguen con el placeholder CHANGE_ME en un perfil != test):
#   DB_PASSWORD, JWT_SECRET, TOTP_ENCRYPTION_KEY, ANON_IDENTITY_HMAC_KEY
# Sin estas, el backend NO arranca. Las marcadas [FUNCIONAL] no tumban el boot
# pero su feature (push, captcha) queda inoperante si faltan.

# Runtime
PORT=
SPRING_PROFILES_ACTIVE=
FORWARD_HEADERS_STRATEGY=
LAZY_INIT=
SERVER_COMPRESSION_ENABLED=

# Database
DATABASE_URL=
DB_USER=
DB_PASSWORD=
JPA_DDL=
SHOW_SQL=
DB_POOL_MAX=
DB_POOL_MIN=
DB_CONN_TIMEOUT=
DB_IDLE_TIMEOUT=
DB_MAX_LIFETIME=

# Auth / JWT / refresh cookie
JWT_SECRET=
JWT_EXPIRATION=
REFRESH_TOKEN_TTL_DAYS=
REFRESH_COOKIE_SECURE=

# OAuth providers
FRONTEND_BASE_URL=
APP_OAUTH_REDIRECT_BASE=
OAUTH_API_BASE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Email and verification
RESEND_API_KEY=
RESEND_FROM=
EMAIL_VERIFICATION_TTL_HOURS=
EMAIL_VERIFICATION_REQUIRED=

# 2FA / TOTP
TOTP_ISSUER=
TOTP_ENCRYPTION_KEY=
TOTP_ENCRYPTION_SALT=

# CORS
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_PATTERNS=

# Rate limits, cron and monitoring
RATELIMIT_ENABLED=
APP_CRON_SECRET=
PROMETHEUS_ENABLED=
APP_PROMETHEUS_SCRAPE_TOKEN=
STATUS_MONITOR_ENABLED=
STATUS_HEALTH_URL=
STATUS_MONITOR_FIXED_RATE_MS=
STATUS_MONITOR_INITIAL_DELAY_MS=
STATUS_MONITOR_TIMEOUT_MS=

# Cache / Redis
SPRING_CACHE_TYPE=
SPRING_DATA_REDIS_URL=
REDIS_HEALTH_ENABLED=

# Product features
TOURNAMENT_AUTO_ENABLED=
COMENTARIOS_RATE_LIMIT_PER_HOUR=
COMENTARIOS_PROFANITY_STEMS=
IMAGES_BASE_URL=
APP_TRUSTED_PROXIES_ALLOW_PRIVATE=
APP_INDEXNOW_KEY=
APP_INDEXNOW_HOST=
APP_INDEXNOW_BASE_URL=

# Anti-fraude del voto anónimo
# ANON_IDENTITY_HMAC_KEY es REQUIRED: firma la cookie de identidad anónima y
# el arranque falla si sigue en CHANGE_ME (perfil != test).
ANON_IDENTITY_HMAC_KEY=
ANON_IDENTITY_COOKIE_NAME=
ANON_IDENTITY_COOKIE_TTL_DAYS=
ANON_ABUSE_SOFT_PER_HOUR=
ANON_ABUSE_HARD_PER_HOUR=
ANON_ABUSE_BLOCK_PER_24H=

# Captcha Cloudflare Turnstile [FUNCIONAL: sin esto el captcha no valida]
TURNSTILE_ENABLED=
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=
TURNSTILE_ENDPOINT=

# Web Push / VAPID [FUNCIONAL: sin las keys el push web no se envía]
# Genera el par de claves fuera del repo (web-push generate-vapid-keys).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
PUSH_ALLOWED_ENDPOINT_HOSTS=

# Audit log: retención y limpieza automática
AUDIT_CLEANUP_ENABLED=
AUDIT_CLEANUP_CRON=
AUDIT_CLEANUP_RETENTION_DAYS=
AUDIT_CLEANUP_SENSITIVE_RETENTION_DAYS=

# Cartas coleccionables — economía de moneda blanda (tuneable sin recompilar)
CARTAS_SOBRE_PRECIO=
CARTAS_DROP_VOTO=
CARTAS_DROP_VOTO_CADA_N=
CARTAS_DROP_MISION_DIARIA=
CARTAS_DROP_TORNEO=
CARTAS_DROP_DUELO=
CARTAS_DROP_TOPE_DIARIO=

# Alertas de movimiento de personaje favorito (job programado)
ALERTAS_FAVORITO_ENABLED=
ALERTAS_FAVORITO_CRON=
ALERTAS_FAVORITO_UMBRAL=
ALERTAS_FAVORITO_VENTANA_DIAS=

# Misceláneo
# PRODUCT_ZONE: zona horaria canónica del producto para resets diarios (UTC).
PRODUCT_ZONE=
JIKAN_BASE_URL=
DUEL_LIVE_FALLBACK_AFTER_SECONDS=
SUGERENCIAS_RATE_LIMIT_PER_HOUR=

# Observabilidad / logging estructurado
# Logging JSON nativo de Spring Boot 3.4+ (sin dependencias). Vacío = consola
# legible (dev). En producción pon "ecs" para emitir JSON ECS que Railway/un
# colector agregan y correlacionan. Spring lo mapea a logging.structured.format.console.
LOGGING_STRUCTURED_FORMAT_CONSOLE=
