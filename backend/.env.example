# =====================================================
# Variables de entorno para AnimeShowdown backend
# =====================================================
# Copia este archivo a `.env` (que NO se commitea) y rellena con valores reales.
# Para producción, configura estas mismas variables en el panel del proveedor
# (Koyeb, Railway, Render, etc.).

# --- Base de datos ---
# URL completa JDBC. Para Neon usa el formato:
# jdbc:postgresql://HOST/DBNAME?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/animeshowdown_db
DB_USER=animeshowdown_user
DB_PASSWORD=cambia_esto_en_produccion

# --- JWT ---
# Genera una clave aleatoria larga (>= 32 chars) con:
#   openssl rand -base64 64
JWT_SECRET=cambia_esto_por_una_clave_larga_aleatoria_en_produccion
# Tiempo de vida del token en milisegundos (3600000 = 1 hora)
JWT_EXPIRATION=3600000

# --- JPA / Hibernate ---
# update | validate | none | create | create-drop
# En producción usa `validate` o `none` para no auto-modificar el esquema
JPA_DDL=update
# Muestra SQL en logs (false en producción)
SHOW_SQL=true

# --- Server ---
# Puerto en el que escucha Spring (los PaaS suelen inyectarlo)
PORT=8080
